# Optional. The app runs with defaults if this file is not copied to .env.

MQCHAIN_AI_APP_NAME=MQCHAIN Intake Console
MQCHAIN_AI_APP_DEBUG=false
MQCHAIN_AI_API_PREFIX=/api

# Default local SQLite database.
MQCHAIN_AI_DATABASE_URL=sqlite:///./data/mqchain_ai.db

# Local artifact storage.
MQCHAIN_AI_SOURCE_UPLOAD_DIR=./data/source_uploads
MQCHAIN_AI_STAGED_ARTIFACT_DIR=./data/staged_artifacts

# Intake limits.
MQCHAIN_AI_SOURCE_UPLOAD_MAX_BYTES=25000000
MQCHAIN_AI_SOURCE_FETCH_TIMEOUT_SECONDS=10
MQCHAIN_AI_SOURCE_FETCH_MAX_BYTES=10000000
MQCHAIN_AI_PREVIEW_CANDIDATE_LIMIT=100
MQCHAIN_AI_MAX_EXTRACTION_CANDIDATES_PER_JOB=10000
MQCHAIN_AI_PDF_MAX_PAGES=50
